@startuml GraPhens

' Style settings
skinparam componentStyle uml2
skinparam component {
    BackgroundColor LightBlue
    BorderColor DarkBlue
}

' Core interfaces
interface PhenotypeLoader
interface AugmentationService
interface EmbeddingStrategy
interface AdjacencyListBuilder
interface GraphAssembler
interface PhenotypeVisualizer

' Core types
class Phenotype {
    +id: String
    +name: String
}

class Graph {
    +node_features: float[]
    +edge_index: int[]
}

' Core Module
package "Core Module" {
    interface CoreInterfaces
}

' Ontology Module
package "Ontology Module" {
    class HPOGraphProvider {
        +load()
        +get_ancestors()
        +get_descendants()
    }
}

' Augmentation Module
package "Augmentation Module" {
    class HPOAugmentationService {
        +augment(phenotypes)
    }
}

' Embedding Module
package "Embedding Module" {
    class EmbeddingContext
    class SentenceTransformerEmbeddingStrategy
    class LookupEmbeddingStrategy
}

' Graph Module
package "Graph Module" {
    class HPOAdjacencyListBuilder
    class StandardGraphAssembler
}

' Visualization Module
package "Visualization Module" {
    class GraphvizVisualizer
}

' Inheritance relationships
HPOGraphProvider -up-|> PhenotypeLoader
HPOAugmentationService -up-|> AugmentationService
SentenceTransformerEmbeddingStrategy -up-|> EmbeddingStrategy
LookupEmbeddingStrategy -up-|> EmbeddingStrategy
HPOAdjacencyListBuilder -up-|> AdjacencyListBuilder
StandardGraphAssembler -up-|> GraphAssembler
GraphvizVisualizer -up-|> PhenotypeVisualizer

' Dependencies
HPOAugmentationService -down-> HPOGraphProvider
EmbeddingContext -right-> EmbeddingStrategy
HPOAdjacencyListBuilder -down-> HPOGraphProvider
StandardGraphAssembler -right-> Phenotype
StandardGraphAssembler -left-> Graph
GraphvizVisualizer -right-> Phenotype
GraphvizVisualizer -left-> Graph

@enduml 